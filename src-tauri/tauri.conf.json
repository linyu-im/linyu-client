{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Linyu",
  "version": "0.1.0",
  "identifier": "chat.linyu",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "登录",
        "url": "/login",
        "label": "login",
        "width": 336,
        "height": 580,
        "fullscreen": false,
        "resizable": false,
        "center": true,
        "skipTaskbar": false,
        "transparent": true,
        "decorations": false,
        "windowEffects":{
          "effects": ["acrylic"],
          "state": "active"
        }
      },
      {
        "title": "linyu",
        "label": "tray",
        "url": "/tray",
        "resizable": false,
        "center": false,
        "visible": false,
        "width": 70,
        "height": 40,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": [
      "html"
    ],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}