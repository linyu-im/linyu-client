{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "linyu-client",
  "version": "0.1.0",
  "identifier": "chat.linyu",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "linyu-client",
        "url": "/login",
        "width": 320,
        "height": 500,
        "fullscreen": false,
        "resizable": false,
        "center": true,
        "skipTaskbar": false,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}